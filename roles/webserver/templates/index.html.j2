<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stephen Cotton — AWS EC2 Ansible</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 50px auto;
            padding: 20px;
            background-color: #f5f5f5;
        }
        h1 { color: #1a56a0; }
        .info { background: #fff; padding: 20px; border-radius: 8px; margin: 20px 0; }
        .label { font-weight: bold; color: #555; }
    </style>
</head>
<body>
    <h1>AWS EC2 Automation — Ansible</h1>

    <div class="info">
        <p><span class="label">Deployed by:</span> Stephen Cotton</p>

        <!-- Ansible automatically fills in these variables at deploy time -->
        <p><span class="label">Server hostname:</span> {{ ansible_hostname }}</p>
        <p><span class="label">Server IP:</span> {{ ansible_default_ipv4.address }}</p>
        <p><span class="label">Operating System:</span> {{ ansible_distribution }} {{ ansible_distribution_version }}</p>
        <p><span class="label">Deployed with:</span> Ansible Automation</p>
    </div>

    <div class="info">
        <h2>Stack</h2>
        <p>Ansible · AWS EC2 · Amazon Linux 2 · Apache</p>
    </div>
</body>
</html>
